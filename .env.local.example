# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Places API (optional - mock data used if missing)
GOOGLE_PLACES_API_KEY=

# Google Solar API (optional - mock data used if missing)
GOOGLE_SOLAR_API_KEY=

# Supabase Service Role Key (required for admin features, NEVER expose publicly)
SUPABASE_SERVICE_ROLE_KEY=

# Provider mode: "mock" | "live"
NEXT_PUBLIC_PROVIDER_MODE=mock
